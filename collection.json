        {
          "name": "Register - Commercant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {\r",
                  "  const json = pm.response.json();\r",
                  "  pm.collectionVariables.set('token', json.token);\r",
                  "  console.log('Token sauvegardé:', json.token);\r",
                  "  pm.test('Compte créé avec succès', () => pm.expect(pm.response.code).to.equal(201));\r",
                  "  pm.test('Token présent', () => pm.expect(json.token).to.be.a('string'));\r",
                  "  pm.test('Rôle = merchant', () => pm.expect(json.user.role).to.equal('merchant'));\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
